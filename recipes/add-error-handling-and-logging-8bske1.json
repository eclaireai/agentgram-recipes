      "action": "create_file",
      "target": "{src_errors}/AppError.ts",
      "description": "Create custom error classes: NotFound, Validation, Auth"
    },
    {
      "action": "create_file",
      "target": "{src_middleware}/error-handler.ts",
      "description": "Create global error handler middleware"
    },
    {
      "action": "create_file",
      "target": "{src_middleware}/request-logger.ts",
      "description": "Create request logging middleware"
    },
    {
      "action": "modify_file",
      "target": "{src}/app.ts",
      "description": "Register logger and error handler middleware"
    },
    {
      "action": "create_file",
      "target": "{tests}/errors.test.ts",
      "description": "Test error handling"
    },
    {
      "action": "run_command",
      "target": "npm test",
      "description": "Verify tests pass"
    }
  ],
